# ─── Application ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=api
API_VERSION=v1
APP_NAME=Learnitali
FRONTEND_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# ─── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://learnitali:password@localhost:5432/learnitali_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─── JWT ────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your-super-secret-access-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Redis ──────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=300
REDIS_DB=0

# ─── S3 / Storage ───────────────────────────────────────────────
STORAGE_PROVIDER=s3
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=learnitali-media
AWS_S3_ENDPOINT=                      # Leave empty for AWS, set for MinIO
CDN_URL=https://cdn.learnitali.com

# ─── Email (SMTP) ────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SMTP_FROM=noreply@learnitali.com
SMTP_FROM_NAME=Learnitali

# ─── Google OAuth ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# ─── Rate Limiting ───────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
THROTTLE_AUTH_LIMIT=5

# ─── Stripe (future) ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Sentry (error tracking) ─────────────────────────────────────
SENTRY_DSN=
